# Agent Factory Core — Environment Variables
# Copia este fichero como .env y rellena los valores reales
# NUNCA commitees el fichero .env con datos reales

# ============================================================
# BASE DE DATOS
# ============================================================
DATABASE_URL=postgresql+asyncpg://agentfactory:agentfactory@localhost:5432/agentfactory

# ============================================================
# REDIS (Cache + Job Queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# LLM PROVIDERS (añade solo los que uses)
# ============================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...

# Para Ollama (local, no necesita key)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# AUTENTICACIÓN
# ============================================================
# Generar con: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# APLICACIÓN
# ============================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# QDRANT (Vector DB, opcional para RAG)
# ============================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================
# PROMPTFOO (Evaluaciones)
# ============================================================
PROMPTFOO_CONFIG_DIR=./templates/promptfoo
EVAL_MIN_SCORE=0.85

# ============================================================
# COSTOS Y LÍMITES
# ============================================================
DEFAULT_DAILY_COST_BUDGET_USD=10.0
DEFAULT_RATE_LIMIT_PER_MINUTE=60
